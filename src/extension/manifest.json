{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0",
  "description": "Analyze and detect phishing URLs using AI-driven behavioral and semantic analysis.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}